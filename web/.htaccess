# Flutter Web SPA fallback.
#
# go_router uses path-based URLs (/, /login, /company/:id, /booking/...).
# Apache serves static files from build/web/, but non-file URLs like /login
# have no matching file on disk and return 404 by default. This rule falls
# back to index.html so the SPA can pick up the path and client-route it.

RewriteEngine On

# Pretty URLs for static legal pages. Needs to come BEFORE the SPA fallback
# so Apache serves the real HTML file instead of index.html. Each legal
# document ships in 3 language variants; the canonical URL is the FR one
# (default in Kosovo + diaspora FR), EN and SQ via /terms/en and /terms/sq.
RewriteRule ^privacy/?$ privacy.html [L]
RewriteRule ^terms/?$ terms.html [L]
RewriteRule ^terms/en/?$ terms-en.html [L]
RewriteRule ^terms/sq/?$ terms-sq.html [L]

# If the request matches an existing file or directory, serve it directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, send everything else to the SPA entry point.
RewriteRule ^ index.html [L]

# Security — don't serve dotfiles to the browser (including this one).
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
