# Termini im — landing page (.htaccess for Apache shared hosting)
# Clean URLs sans extension .html — /terms, /privacy, /terms-en, etc.

RewriteEngine On

# 1. Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} ^(.+)$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# 2. Redirige les URLs *.html vers la version sans extension (canonical)
RewriteCond %{THE_REQUEST} \s/+([^?]+)\.html[?\s] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 3. Sert le .html en interne quand l'URL n'a pas d'extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# 4. Cache-Control — assets statiques 1 an, HTML 5 minutes
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/svg+xml  "access plus 1 year"
  ExpiresByType image/jpeg  "access plus 1 year"
  ExpiresByType text/css  "access plus 1 month"
  ExpiresByType application/javascript  "access plus 1 month"
  ExpiresByType text/html  "access plus 5 minutes"
</IfModule>

# 5. Compression GZIP — réduit le poids du HTML/CSS/JS
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 6. Sécurité headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "interest-cohort=()"
</IfModule>

# 7. Page 404 personnalisée — fallback sur l'index si la route n'existe pas
ErrorDocument 404 /index.html
